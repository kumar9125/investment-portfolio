# ══════════════════════════════════════════════════════════════════════════════
#  Investment Portfolio Tracker – Environment Variable Reference
# ══════════════════════════════════════════════════════════════════════════════
#  Copy this file to .env (never commit .env).
#  On Render, set these as Environment Variables in the dashboard.
# ══════════════════════════════════════════════════════════════════════════════

# ── FRONTEND (Vite) ───────────────────────────────────────────────────────────
# Full URL of your deployed backend API (no trailing slash)
# Local:      http://localhost:5000/api
# Production: https://investment-tracker-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ── BACKEND (Node / Express) ──────────────────────────────────────────────────
# Port the Express server listens on (Render overrides this automatically)
PORT=5000

# MongoDB connection string (use MongoDB Atlas for production)
# Example Atlas URI: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio_tracker?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/portfolio_tracker

# JWT signing secret – use a long, random string (min 64 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_real_random_secret

# Environment mode
NODE_ENV=development

# Deployed frontend URL (used for CORS in production)
# Example: https://investment-tracker-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
