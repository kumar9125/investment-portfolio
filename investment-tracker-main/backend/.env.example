# ══════════════════════════════════════════════════════════════════════════════
#  Backend Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#  Copy to backend/.env  (never commit .env)
# ══════════════════════════════════════════════════════════════════════════════

# Port (Render overrides this automatically – leave as 5000 for local)
PORT=5000

# MongoDB connection string
# Local:   mongodb://localhost:27017/portfolio_tracker
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio_tracker?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/portfolio_tracker

# JWT secret – long random hex string
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_real_random_secret

# production | development
NODE_ENV=development

# Deployed frontend origin for CORS (no trailing slash)
# Example: https://investment-tracker-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
